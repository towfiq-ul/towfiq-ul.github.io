# EmailJS Configuration
# Get these values from https://www.emailjs.com/

# Your EmailJS Public Key (from Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (from Email Services)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (from Email Templates)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Email address where you want to receive contact form submissions
VITE_RECEIVER_EMAIL=your_receiver_email_here

VITE_OPEN_AI_BASE_URL=''
VITE_OPEN_AI_MODEL=''
VITE_OPEN_AI_API_KEY=''
VITE_OPEN_AI_TEMPERATURE=0.5

VITE_CV_FILE_PATHS=''
VITE_AI_CONTEXT_DATA_URL=''
VITE_SCRAPPER_DOMAIN=''
VITE_SCRAPPER_TOKEN=''
VITE_SCRAPPER_RETRY_MAX_COUNT=10